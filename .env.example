# Dashboard Auth
DASHBOARD_API_KEY=your_secret_key_here

# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/aipromo

# Unipile (https://www.unipile.com/)
UNIPILE_DSN=api1.unipile.com:13111
UNIPILE_ACCESS_TOKEN=your_token_here
UNIPILE_ACCOUNTS=[{"alias":"main","id":"your_account_id","name":"Your Name"}]
UNIPILE_DEFAULT_ACCOUNT=main
LINKEDIN_COMPANY_IDS=your_company_id

# AWS Bedrock
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-central-1
BEDROCK_MODEL=eu.anthropic.claude-sonnet-4-6

# Rate Limits
MAX_MESSAGES_PER_DAY=50
MAX_INVITATIONS_PER_DAY=20
# Steady email cap — keep at 80 to match SES declared use-case (<100/day)
MAX_EMAILS_PER_DAY=80
MIN_DELAY_SECONDS=3
MAX_DELAY_SECONDS=8
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18

# SMTP — personal email communication with clients via own mail server
SMTP_HOST=mail2.legal.org.ua
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=igor@legal.org.ua
SMTP_PASSWORD=your_mailbox_password
SMTP_FROM_NAME=Ihor Kyrychenko
SMTP_FROM_EMAIL=igor@legal.org.ua
SMTP_REPLY_TO=igor@legal.org.ua
# Public base URL for unsubscribe links + secret to sign unsubscribe tokens
PUBLIC_BASE_URL=https://crm.legal.org.ua
UNSUBSCRIBE_SECRET=change_me_to_a_long_random_string

# SES relay reputation / warm-up (mail server relays outbound through AWS SES)
SES_REGION=eu-central-1
EMAIL_WARMUP_ENABLED=true
EMAIL_WARMUP_START_DATE=2026-07-02
EMAIL_MAX_BOUNCE_RATE=0.05
EMAIL_MAX_COMPLAINT_RATE=0.001
# SNS topic that SES publishes bounce/complaint notifications to (webhook: /webhook/ses)
SES_SNS_TOPIC_ARN=arn:aws:sns:eu-central-1:272594900302:ses-notifications-legal

# Persona
SENDER_NAME=Your Name
SENDER_COMPANY=Your Company
SENDER_ROLE=Your Title
CAMPAIGN_OBJECTIVE=Book a discovery call
